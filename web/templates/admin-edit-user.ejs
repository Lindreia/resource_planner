<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit User | Resource Planner</title>
    <link rel="stylesheet" href="/static/style.css">
</head>

<body class="login-body logo-bg">

    <div class="login-container fade-in">

        <h2>Edit User</h2>
        <p class="subtitle">Update user details, role, or password</p>

        <% if (error) { %>
            <div class="error-box"><%= error %></div>
        <% } %>

        <% if (message) { %>
            <div class="success-box"><%= message %></div>
        <% } %>

        <form method="POST" action="/admin/edit-user/<%= user.id %>">

            <div class="input-group">
                <label>Name</label>
                <input 
                    type="text" 
                    name="name" 
                    value="<%= user.name %>" 
                    required
                >
            </div>

            <div class="input-group">
                <label>Email</label>
                <input 
                    type="email" 
                    name="email" 
                    value="<%= user.email %>" 
                    required
                >
            </div>

            <div class="input-group">
                <label>Role</label>
                <select name="role" class="role-select" required>
                    <option value="staff" <%= user.role === 'staff' ? 'selected' : '' %>>Staff</option>
                    <option value="manager" <%= user.role === 'manager' ? 'selected' : '' %>>Manager</option>
                    <option value="viewer" <%= user.role === 'viewer' ? 'selected' : '' %>>Viewer</option>
                    <option value="client" <%= user.role === 'client' ? 'selected' : '' %>>External Client</option>
                    <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                </select>
            </div>

            <div class="input-group">
                <label>Weekly Capacity (hours)</label>
                <input
                    type="number"
                    name="weekly_capacity"
                    min="1"
                    max="80"
                    step="0.5"
                    value="<%= user.weekly_capacity %>"
                    required
                >
            </div>

            <div class="input-group">
                <label>Working Days</label>
                <div class="d-flex flex-wrap gap-2">
                    <label><input type="checkbox" name="working_days" value="Mon" <%= user.selected_working_days && user.selected_working_days.includes('Mon') ? 'checked' : '' %>> Mon</label>
                    <label><input type="checkbox" name="working_days" value="Tue" <%= user.selected_working_days && user.selected_working_days.includes('Tue') ? 'checked' : '' %>> Tue</label>
                    <label><input type="checkbox" name="working_days" value="Wed" <%= user.selected_working_days && user.selected_working_days.includes('Wed') ? 'checked' : '' %>> Wed</label>
                    <label><input type="checkbox" name="working_days" value="Thu" <%= user.selected_working_days && user.selected_working_days.includes('Thu') ? 'checked' : '' %>> Thu</label>
                    <label><input type="checkbox" name="working_days" value="Fri" <%= user.selected_working_days && user.selected_working_days.includes('Fri') ? 'checked' : '' %>> Fri</label>
                    <label><input type="checkbox" name="working_days" value="Sat" <%= user.selected_working_days && user.selected_working_days.includes('Sat') ? 'checked' : '' %>> Sat</label>
                    <label><input type="checkbox" name="working_days" value="Sun" <%= user.selected_working_days && user.selected_working_days.includes('Sun') ? 'checked' : '' %>> Sun</label>
                </div>
            </div>

            <div class="input-group">
                <label>New Password (optional)</label>
                <div class="password-wrapper">
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        placeholder="Leave blank to keep current password"
                    >
                    <span class="toggle-password" onclick="togglePassword()">👁️</span>
                </div>
            </div>

            <button class="login-btn" type="submit">Save Changes</button>

            <div class="theme-toggle" onclick="toggleTheme()">
                🌙 Dark Mode
            </div>

        </form>

        <div class="footer-links">
            <a href="/admin/users">Back to User List</a>
        </div>

    </div>

<script>
function togglePassword() {
    const field = document.getElementById("password");
    field.type = field.type === "password" ? "text" : "password";
}

function toggleTheme() {
    const root = document.documentElement;
    const current = root.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
}

const saved = localStorage.getItem("theme");
if (saved) {
    document.documentElement.setAttribute("data-theme", saved);
}
</script>

</body>
</html>
