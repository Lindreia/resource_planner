<div class="container">
    <h1 class="r8-page-title mb-4">Daily Dashboard</h1>

    <div class="dashboard-card mb-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="/daily?date=<%= previous_date %>">Previous Day</a>
            <strong><%= selected_date %></strong>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-sm btn-outline-success" href="/exports/daily.csv?date=<%= selected_date %>">Export CSV</a>
                <a class="btn btn-sm btn-outline-primary" href="/exports/daily.pdf?date=<%= selected_date %>">Export PDF</a>
                <a class="btn btn-sm btn-outline-secondary" href="/daily?date=<%= next_date %>">Next Day</a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Hours By Team Member</div>
                <canvas id="dailyHoursChart" height="140"></canvas>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Booked Team Members</div>
                <div class="dashboard-kpi"><%= by_user.length %></div>
                <div class="dashboard-kpi-label">With Entries On Selected Day</div>
            </div>
        </div>
    </div>

    <div class="dashboard-card mt-4">
        <div class="dashboard-card-title">Daily Detail</div>
        <table class="dashboard-mini-table w-100">
            <tr>
                <th>Team Member</th>
                <th>Total Hours</th>
                <th>Projects</th>
            </tr>
            <% if (by_user.length > 0) { %>
                <% by_user.forEach(row => { %>
                    <tr>
                        <td><%= row.name %></td>
                        <td><%= row.total.toFixed(2) %></td>
                        <td>
                            <% row.items.forEach(item => { %>
                                <span class="project-dot" style="background-color: <%= item.color || '#0b8a4a' %>"></span>
                                <%= item.project_code %> (<%= item.hours %>h)
                                <br>
                            <% }) %>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="3" class="text-muted">No bookings for this date</td></tr>
            <% } %>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
    const labels = <%- JSON.stringify(by_user.map(r => r.name)) %>;
    const hours = <%- JSON.stringify(by_user.map(r => Number(r.total.toFixed(2)))) %>;

    const ctx = document.getElementById("dailyHoursChart");
    if (ctx) {
        new Chart(ctx, {
            type: "bar",
            data: {
                labels,
                datasets: [{
                    label: "Hours",
                    data: hours,
                    backgroundColor: "#0b8a4a"
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });
    }
})();
</script>
