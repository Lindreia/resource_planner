<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "Resource Planner" %></title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- BOOTSTRAP ICONS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- GLOBAL CSS -->
    <link rel="stylesheet" href="/static/style.css">
</head>

<body>

    <% const showSidebar = false; %>

    <!-- SIDEBAR -->
    <% if (showSidebar) { %>
        <%- include("sidebar") %>
    <% } %>

    <!-- MAIN CONTENT AREA -->
    <main class="p-4" id="mainContent" style="margin-left: <%= showSidebar ? '220px' : '0' %>; transition: margin-left 0.25s ease;">
        
        <!-- FLASH MESSAGES -->
        <% if (messages && messages.length > 0) { %>
            <% messages.forEach(msg => { %>
                <div class="alert alert-<%= msg.category %> mt-2">
                    <%= msg.message %>
                </div>
            <% }) %>
        <% } %>

        <!-- PAGE CONTENT -->
        <%- body %>
    </main>

    <!-- BOOTSTRAP JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- COLOR DOT SCRIPT -->
    <script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll("[data-color]").forEach(el => {
            const color = el.dataset.color;
            if (color) el.style.backgroundColor = color;
        });
    });
    </script>

    <!-- SIDEBAR COLLAPSE SCRIPT -->
    <% if (showSidebar) { %>
        <script>
        const sidebar = document.getElementById("sidebar");
        const mainContent = document.getElementById("mainContent");
        const toggleBtn = document.getElementById("sidebarToggle");

        toggleBtn.addEventListener("click", () => {
            sidebar.classList.toggle("collapsed");

            if (sidebar.classList.contains("collapsed")) {
                mainContent.style.marginLeft = "70px";
            } else {
                mainContent.style.marginLeft = "220px";
            }

            localStorage.setItem("sidebar-collapsed", sidebar.classList.contains("collapsed"));
        });

        // Restore state
        window.addEventListener("DOMContentLoaded", () => {
            if (localStorage.getItem("sidebar-collapsed") === "true") {
                sidebar.classList.add("collapsed");
                mainContent.style.marginLeft = "70px";
            }
        });
        </script>
    <% } %>

    <!-- GLOBAL CONFLICT MODAL -->
    <div class="modal fade" id="conflictModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

          <div class="modal-header bg-danger text-white">
            <h5 class="modal-title">Booking Conflict</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body" id="conflictMessage"></div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">OK</button>
          </div>

        </div>
      </div>
    </div>

</body>
</html>
