<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 mb-4">Add Assignment</h1>

                    <form id="assignmentForm">
                        <div class="mb-3">
                            <label class="form-label">Team Member</label>
                            <select name="team_member" class="form-select" required>
                                <option value="">Select...</option>
                                <% team_members.forEach(member => { %>
                                    <option value="<%= member.id %>"><%= member.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Project</label>
                            <select name="project" class="form-select" required>
                                <option value="">Select...</option>
                                <% projects.forEach(project => { %>
                                    <option value="<%= project.id %>"><%= project.project_code %> - <%= project.project_name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Date</label>
                                <input type="date" name="start_date" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">End Date</label>
                                <input type="date" name="end_date" class="form-control" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Time</label>
                                <input type="time" name="start_time" class="form-control" value="07:00" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">End Time</label>
                                <input type="time" name="end_time" class="form-control" value="17:00" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Hours per Week</label>
                            <input type="number" name="hours_per_week" class="form-control" min="1" max="80" required>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" type="submit">Add Assignment</button>
                            <a href="/weekly" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="conflictModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Assignment Conflict</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="conflictMessage"></div>
        </div>
    </div>
</div>

<script>
document.getElementById("assignmentForm").addEventListener("submit", async function (event) {
    event.preventDefault();

    const response = await fetch("/assignments/add", {
        method: "POST",
        body: new FormData(this)
    });

    const data = await response.json();

    if (!response.ok) {
        document.getElementById("conflictMessage").innerHTML = `<div class="alert alert-warning mb-0">${data.error || "Unable to add assignment"}</div>`;
        new bootstrap.Modal(document.getElementById("conflictModal")).show();
        return;
    }

    window.location.href = "/weekly";
});
</script>
