{% extends "base.html" %}
{% block content %}

<h2 class="mb-4">Add Assignment</h2>

<div class="r8-card p-4">
    <form id="assignmentForm">

        <!-- TEAM MEMBER -->
        <div class="mb-3">
            <label class="form-label">Team Member</label>
            <select name="team_member" class="form-select" required>
                <option value="">Select...</option>
                {% for id, name in team_members %}
                <option value="{{ id }}">{{ name }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- PROJECT -->
        <div class="mb-3">
            <label class="form-label">Project</label>
            <select name="project" class="form-select" required>
                <option value="">Select...</option>
                {% for id, code, name in projects %}
                <option value="{{ id }}">{{ code }} — {{ name }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- DATES -->
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Start Date</label>
                <input type="date" name="start_date" class="form-control" required>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">End Date</label>
                <input type="date" name="end_date" class="form-control" required>
            </div>
        </div>

        <!-- TIMES -->
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Start Time</label>
                <input type="time" name="start_time" class="form-control" value="07:00" required>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">End Time</label>
                <input type="time" name="end_time" class="form-control" value="17:00" required>
            </div>
        </div>

        <!-- HOURS -->
        <div class="mb-3">
            <label class="form-label">Hours per Week</label>
            <input type="number" name="hours_per_week" class="form-control" min="1" max="80" required>
        </div>

        <!-- WORK DAYS -->
        <div class="mb-3">
            <label class="form-label">Work Days</label>
            <input type="text" name="work_days" class="form-control" placeholder="Mon-Fri, Wed, Mon, Wed, Fri" required>
        </div>

        <!-- REQUESTED BY -->
        <div class="mb-3">
            <label class="form-label">Requested By (admin or user)</label>
            <input type="text" name="requested_by" class="form-control" required>
        </div>

        <!-- BUTTONS -->
        <button class="btn btn-primary">Add Assignment</button>
        <a href="{{ url_for('weekly') }}" class="btn btn-secondary">Cancel</a>

    </form>
</div>

<!-- AJAX + MODAL LOGIC -->
<script>
document.getElementById("assignmentForm").addEventListener("submit", async function(e) {
    e.preventDefault();

    const formData = new FormData(this);

    const response = await fetch("/assignments/add", {
        method: "POST",
        body: formData
    });

    const data = await response.json();

    if (!response.ok) {
        // SHOW EXACT CONFLICT DETAILS
        document.getElementById("conflictMessage").innerHTML = `
            <p>This assignment overlaps with an existing booking:</p>

            <div class="alert alert-warning">
                <strong>${data.error}</strong>
            </div>

            <p>Please adjust the dates or times.</p>
        `;

        const modal = new bootstrap.Modal(document.getElementById("conflictModal"));
        modal.show();
        return;
    }

    // SUCCESS → redirect
    window.location.href = "/weekly";
});
</script>

{% endblock %}
