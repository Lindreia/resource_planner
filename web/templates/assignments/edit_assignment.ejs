<%- include("../partials/header") %>

<h2 class="mb-4">Edit Assignment</h2>

<div class="r8-card p-4">
    <form method="POST">

        <!-- TEAM MEMBER -->
        <div class="mb-3">
            <label class="form-label">Team Member</label>
            <select name="team_member" class="form-select" required>
                <option value="">Select...</option>
                <% team_members.forEach(tm => { %>
                    <option value="<%= tm.id %>" 
                        <%= assignment.team_member === tm.id ? "selected" : "" %>>
                        <%= tm.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- PROJECT -->
        <div class="mb-3">
            <label class="form-label">Project</label>
            <select name="project" class="form-select" required>
                <option value="">Select...</option>
                <% projects.forEach(p => { %>
                    <option value="<%= p.id %>"
                        <%= assignment.project === p.id ? "selected" : "" %>>
                        <%= p.code %> — <%= p.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- DATES -->
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Start Date</label>
                <input type="date" name="start_date" class="form-control"
                       value="<%= assignment.start_date %>" required>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">End Date</label>
                <input type="date" name="end_date" class="form-control"
                       value="<%= assignment.end_date %>" required>
            </div>
        </div>

        <!-- TIMES -->
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Start Time</label>
                <input type="time" name="start_time" class="form-control"
                       value="<%= assignment.start_time %>" autocomplete="off" required>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">End Time</label>
                <input type="time" name="end_time" class="form-control"
                       value="<%= assignment.end_time %>" autocomplete="off" required>
            </div>
        </div>

        <!-- HOURS -->
        <div class="mb-3">
            <label class="form-label">Hours per Week</label>
            <input type="number" name="hours_per_week" class="form-control"
                   min="1" max="80" value="<%= assignment.hours_per_week %>" required>
        </div>

        <!-- WORK DAYS -->
        <div class="mb-3">
            <label class="form-label">Work Days</label>
            <input type="text" name="work_days" class="form-control"
                   value="<%= assignment.work_days %>" required>
        </div>

        <!-- REQUESTED BY -->
        <div class="mb-3">
            <label class="form-label">Requested By (admin or user)</label>
            <input type="text" name="requested_by" class="form-control"
                   value="<%= assignment.requested_by %>" required>
        </div>

        <!-- BUTTONS -->
        <button class="btn btn-primary">Update Assignment</button>
        <a href="/weekly" class="btn btn-secondary">Cancel</a>

    </form>
</div>

<%- include("../partials/footer") %>
