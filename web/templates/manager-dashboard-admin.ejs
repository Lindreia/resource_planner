<div class="container dashboard-container">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="r8-page-title mb-1">Manager Dashboard (Admin View)</h1>
            <p class="text-muted mb-0">Manager metrics without manager sidebar navigation.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/admin/dashboard" class="btn btn-outline-secondary btn-sm">Admin Dashboard</a>
            <a href="/manager/projects" class="btn btn-outline-success btn-sm">Projects</a>
            <a href="/manager/bookings" class="btn btn-outline-success btn-sm">Bookings</a>
            <a href="/manager/approvals" class="btn btn-outline-success btn-sm">Approvals</a>
        </div>
    </div>

    <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Your Team Members</div>
                <div class="dashboard-kpi"><%= stats.teamCount %></div>
                <div class="dashboard-kpi-label">Active Staff</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Bookings Today</div>
                <div class="dashboard-kpi"><%= stats.todayBookings %></div>
                <div class="dashboard-kpi-label">Hours Logged</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Pending Approvals</div>
                <div class="dashboard-kpi"><%= stats.pendingApprovals %></div>
                <div class="dashboard-kpi-label">Awaiting Review</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Active Projects</div>
                <div class="dashboard-kpi"><%= stats.projectCount %></div>
                <div class="dashboard-kpi-label">In Progress</div>
            </div>
        </div>
    </div>

    <div class="dashboard-card mt-4">
        <div class="dashboard-card-title">Manager Tools</div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-success btn-sm" href="/manager/team">View Team</a>
            <a class="btn btn-success btn-sm" href="/manager/bookings">Manage Bookings</a>
            <a class="btn btn-success btn-sm" href="/manager/approvals">Approve Requests</a>
            <a class="btn btn-success btn-sm" href="/manager/projects">Project Overview</a>
            <a class="btn btn-outline-success btn-sm" href="/admin/overrides">Override Requests</a>
        </div>
    </div>
</div>
