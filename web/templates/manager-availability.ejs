<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Availability | Resource Planner</title>
    <link rel="stylesheet" href="/static/style.css">
</head>

<body data-theme="light">

<div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">R8</span>
            <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
        </div>

        <nav class="sidebar-nav">
            <a href="/manager/dashboard" class="nav-link">📊 <span class="nav-text">Dashboard</span></a>
            <a href="/manager/projects" class="nav-link">📁 <span class="nav-text">Projects</span></a>
            <a href="/manager/availability" class="nav-link active">📅 <span class="nav-text">Availability</span></a>
            <a href="/manager/allocation" class="nav-link">📦 <span class="nav-text">Allocation</span></a>
            <a href="/manager/team" class="nav-link">👥 <span class="nav-text">Team</span></a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="content">

        <h2>Team Availability</h2>
        <p class="subtitle">View availability for your team</p>

        <% if (availability.length === 0) { %>
            <div class="info-text">No availability data found.</div>
        <% } else { %>
            <table class="user-table">
                <tr>
                    <th>User</th>
                    <th>Date</th>
                    <th>Status</th>
                </tr>

                <% availability.forEach(a => { %>
                    <tr>
                        <td><%= a.user_name %></td>
                        <td><%= a.date %></td>
                        <td><%= a.status %></td>
                    </tr>
                <% }) %>
            </table>
        <% } %>

    </main>

</div>

<script>
/* Sidebar collapse */
function toggleSidebar() {
    const s = document.getElementById("sidebar");
    s.classList.toggle("collapsed");
    localStorage.setItem("sidebar-collapsed", s.classList.contains("collapsed"));
}

document.addEventListener("DOMContentLoaded", () => {
    if (localStorage.getItem("sidebar-collapsed") === "true") {
        document.getElementById("sidebar").classList.add("collapsed");
    }
});

/* Theme persistence (matches other pages) */
const saved = localStorage.getItem("theme");
if (saved) {
    document.documentElement.setAttribute("data-theme", saved);
}
</script>

</body>
</html>
