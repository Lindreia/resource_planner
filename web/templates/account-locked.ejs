<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Account Locked | Resource Planner</title>
    <link rel="stylesheet" href="/static/style.css">
</head>

<body class="login-body logo-bg">

    <div class="login-container fade-in">

        <h2>Account Locked</h2>
        <p class="subtitle">
            Your account has been temporarily locked due to multiple failed login attempts.
        </p>

        <div class="error-box">
            For your security, access is blocked for 15 minutes.
        </div>

        <p class="info-text">
            If you believe this is a mistake, please contact an administrator to unlock your account.
        </p>

        <form action="/login" method="GET">
            <button class="login-btn" type="submit">Back to Login</button>
        </form>

        <div class="theme-toggle" onclick="toggleTheme()">
            🌙 Dark Mode
        </div>

    </div>

<script>
function toggleTheme() {
    const root = document.documentElement;
    const current = root.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
}

// Load saved theme
const saved = localStorage.getItem("theme");
if (saved) {
    document.documentElement.setAttribute("data-theme", saved);
}
</script>

</body>
</html>
