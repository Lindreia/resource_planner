<% layout('components/layout') %>

<div class="container dashboard-container">

    <h1 class="r8-page-title mb-4">Admin Dashboard</h1>

    <!-- KPI ROW -->
    <div class="row g-4">

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Total Users</div>
                <div class="dashboard-kpi"><%= stats.totalusers %></div>
                <div class="dashboard-kpi-label">All Accounts</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Locked Accounts</div>
                <div class="dashboard-kpi dashboard-status-red"><%= stats.lockedusers %></div>
                <div class="dashboard-kpi-label">Require Action</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Admins</div>
                <div class="dashboard-kpi"><%= stats.admincount %></div>
                <div class="dashboard-kpi-label">System Admins</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Managers</div>
                <div class="dashboard-kpi"><%= stats.managercount %></div>
                <div class="dashboard-kpi-label">Project Managers</div>
            </div>
        </div>

    </div>

    <!-- ALERTS + RECENT USERS -->
    <div class="row g-4 mt-2">

        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">System Alerts</div>

                <table class="dashboard-mini-table w-100">
                    <tr><th>Alert</th><th class="text-end">Count</th></tr>

                    <tr>
                        <td>Overdue Assignments</td>
                        <td class="text-end dashboard-status-red"><%= alerts.overdueAssignments.length %></td>
                    </tr>

                    <tr>
                        <td>Over Capacity</td>
                        <td class="text-end dashboard-status-amber"><%= alerts.overCapacity.length %></td>
                    </tr>

                    <tr>
                        <td>Empty Projects</td>
                        <td class="text-end dashboard-status-green"><%= alerts.emptyProjects.length %></td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Recent Users</div>

                <table class="dashboard-mini-table w-100">
                    <% recentUsers.forEach(u => { %>
                        <tr>
                            <td><%= u.name %></td>
                            <td class="text-end"><%= u.role %></td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>

    </div>

    <!-- LOCKED ACCOUNTS + CHART -->
    <div class="row g-4 mt-2">

        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Locked Accounts</div>

                <table class="dashboard-mini-table w-100">
                    <% if (lockedList.length > 0) { %>
                        <% lockedList.forEach(u => { %>
                            <tr>
                                <td><%= u.name %> (<%= u.email %>)</td>
                                <td class="text-end">
                                    <a href="/admin/unlock/<%= u.id %>" class="btn btn-sm btn-success">Unlock</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="2" class="text-muted">No locked accounts</td></tr>
                    <% } %>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Assignment Trend</div>
                <canvas id="trendChart" height="120"></canvas>
            </div>
        </div>

    </div>

</div>

<!-- CHART.JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
(function () {

    const months = <%- JSON.stringify(assignmentTrend.map(a => a.month)) %>;
    const counts = <%- JSON.stringify(assignmentTrend.map(a => a.count)) %>;

    new Chart(document.getElementById("trendChart"), {
        type: "line",
        data: {
            labels: months,
            datasets: [{
                label: "Assignments",
                data: counts,
                borderColor: "#0b8a4a",
                backgroundColor: "rgba(11,138,74,0.15)",
                tension: 0.35,
                fill: true
            }]
        },
        options: {
            animation: {
                duration: 1200,
                easing: "easeOutQuart"
            },
            scales: {
                y: { beginAtZero: true }
            }
        }
    });

})();
</script>
