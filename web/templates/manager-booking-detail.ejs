<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking Details | Resource Planner</title>
    <link rel="stylesheet" href="/static/style.css">
</head>

<body data-theme="light">

<div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">R8</span>
            <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
        </div>

        <nav class="sidebar-nav">
            <a href="/manager/dashboard" class="nav-link">📊 <span class="nav-text">Dashboard</span></a>
            <a href="/manager/projects" class="nav-link">📁 <span class="nav-text">Projects</span></a>
            <a href="/manager/availability" class="nav-link">📅 <span class="nav-text">Availability</span></a>
            <a href="/manager/allocation" class="nav-link">📦 <span class="nav-text">Allocation</span></a>
            <a href="/manager/team" class="nav-link">👥 <span class="nav-text">Team</span></a>
            <a href="/manager/bookings" class="nav-link active">🗂 <span class="nav-text">Bookings</span></a>
            <a href="/logout" class="nav-link logout-link">Logout</a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="content">

        <h2>Booking Details</h2>
        <p class="subtitle">Review, approve, or update this booking</p>

        <% if (error) { %>
            <div class="error-box"><%= error %></div>
        <% } %>

        <% if (message) { %>
            <div class="success-box"><%= message %></div>
        <% } %>

        <!-- Booking Summary -->
        <div class="profile-card">
            <p><strong>Team Member:</strong> <%= booking.user_name %></p>
            <p><strong>Project:</strong> <%= booking.project_name %></p>
            <p><strong>Date:</strong> <%= booking.date %></p>
            <p><strong>Status:</strong> <%= booking.status %></p>
        </div>

        <!-- Edit Hours -->
        <h3 class="section-title">Edit Hours</h3>

        <form method="POST" action="/manager/bookings/<%= booking.id %>/update-hours">
            <div class="input-group">
                <label>Hours</label>
                <input 
                    type="number" 
                    name="hours" 
                    min="1" 
                    max="12" 
                    value="<%= booking.hours %>" 
                    required
                >
            </div>

            <button class="login-btn small-btn" type="submit">Update Hours</button>
        </form>

        <!-- Notes -->
        <h3 class="section-title">Notes</h3>

        <form method="POST" action="/manager/bookings/<%= booking.id %>/notes">
            <div class="input-group">
                <textarea 
                    name="notes" 
                    rows="4" 
                    placeholder="Add internal notes for this booking..."
                ><%= booking.notes || '' %></textarea>
            </div>

            <button class="login-btn small-btn" type="submit">Save Notes</button>
        </form>

        <!-- Approval Actions -->
        <h3 class="section-title">Approval</h3>

        <div class="action-buttons">

            <form method="POST" action="/manager/bookings/<%= booking.id %>/approve" class="inline-form">
                <button class="login-btn small-btn" type="submit">Approve</button>
            </form>

            <form method="POST" action="/manager/bookings/<%= booking.id %>/reject" class="inline-form">
                <button class="login-btn small-btn warn-btn" type="submit">Reject</button>
            </form>

        </div>

        <div class="theme-toggle" onclick="toggleTheme()">🌙 Dark Mode</div>

        <div class="footer-links">
            <a href="/manager/bookings">Back to Bookings</a>
        </div>

    </main>

</div>

<script src="/static/logout-modal.js"></script>
<script>
/* Sidebar collapse */
function toggleSidebar() {
    const s = document.getElementById("sidebar");
    s.classList.toggle("collapsed");
    localStorage.setItem("sidebar-collapsed", s.classList.contains("collapsed"));
}

document.addEventListener("DOMContentLoaded", () => {
    if (localStorage.getItem("sidebar-collapsed") === "true") {
        document.getElementById("sidebar").classList.add("collapsed");
    }
});

/* Theme toggle */
function toggleTheme() {
    const root = document.documentElement;
    const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
}

const saved = localStorage.getItem("theme");
if (saved) document.documentElement.setAttribute("data-theme", saved);
</script>

</body>
</html>
