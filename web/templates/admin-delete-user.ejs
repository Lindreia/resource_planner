<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Delete User | Resource Planner</title>
    <link rel="stylesheet" href="/static/style.css">
</head>

<body class="login-body logo-bg">

    <div class="login-container fade-in">

        <h2>Delete User</h2>
        <p class="subtitle">You are about to permanently delete this user</p>

        <div class="warning-box">
            ⚠️ This action cannot be undone.
        </div>

        <div class="user-summary">
            <p><strong>Name:</strong> <%= user.name %></p>
            <p><strong>Email:</strong> <%= user.email %></p>
            <p><strong>Role:</strong> <%= user.role %></p>
        </div>

        <form method="POST" action="/admin/delete-user/<%= user.id %>">
            <button class="login-btn warn-btn" type="submit">Yes, Delete User</button>
        </form>

        <form method="GET" action="/admin/users">
            <button class="login-btn" type="submit">Cancel</button>
        </form>

        <div class="theme-toggle" onclick="toggleTheme()">
            🌙 Dark Mode
        </div>

    </div>

<script>
function toggleTheme() {
    const root = document.documentElement;
    const current = root.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
}

const saved = localStorage.getItem("theme");
if (saved) {
    document.documentElement.setAttribute("data-theme", saved);
}
</script>

</body>
</html>
