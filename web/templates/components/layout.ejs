<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "Resource Planner" %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
        <div class="container-fluid">

            <a class="navbar-brand fw-bold" href="/weekly">
                Resource Planner
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto">

                    <% if (user && ["admin", "manager"].includes((user.role || "").toLowerCase())) { %>
                    <li class="nav-item">
                        <a class="nav-link <%= active_page === 'resources' ? 'active fw-bold' : '' %>"
                           href="/resources">
                            Resource Input
                        </a>
                    </li>
                    <% } %>

                    <li class="nav-item">
                        <a class="nav-link <%= active_page === 'weekly' ? 'active fw-bold' : '' %>"
                           href="/weekly">
                            Weekly Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link <%= active_page === 'monthly' ? 'active fw-bold' : '' %>"
                           href="/monthly">
                            Monthly Planner
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link <%= active_page === 'daily' ? 'active fw-bold' : '' %>"
                           href="/daily">
                            Daily View
                        </a>
                    </li>

                    <% if (user && (user.role || "").toLowerCase() === "admin") { %>
                    <li class="nav-item">
                        <a class="nav-link <%= active_page === 'admin_users' ? 'active fw-bold' : '' %>"
                           href="/admin/users">
                            User Management
                        </a>
                    </li>
                    <% } %>

                    <% if (user) { %>
                    <li class="nav-item dropdown ms-3">
                        <a class="nav-link dropdown-toggle fw-bold" href="#" id="userMenu"
                           role="button" data-bs-toggle="dropdown">
                            <%= user.name %> (<%= user.role %>)
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item logout-link" href="/logout">Logout</a></li>
                        </ul>
                    </li>
                    <% } %>

                </ul>
            </div>

        </div>
    </nav>

    <main>
        <%- body %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/logout-modal.js"></script>
</body>
</html>
