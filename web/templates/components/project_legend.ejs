<div class="r8-card p-4 mt-4">
    <h5 class="mb-3">Project Legend</h5>

    <div class="row g-3">
        <% legend.forEach(p => { %>
        <div class="col-6 col-md-3 d-flex align-items-center gap-2">
            <span class="legend-dot" data-color="<%= p.color %>"></span>
            <span><%= p.code %> — <%= p.name %></span>
        </div>
        <% }) %>
    </div>
</div>
