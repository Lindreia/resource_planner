<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Approval Requests | Resource Planner</title>
    <link rel="stylesheet" href="/static/style.css">
</head>

<body data-theme="light">

<div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">R8</span>
            <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
        </div>

        <nav class="sidebar-nav">
            <a href="/manager/dashboard" class="nav-link">📊 <span class="nav-text">Dashboard</span></a>
            <a href="/manager/projects" class="nav-link">📁 <span class="nav-text">Projects</span></a>
            <a href="/manager/availability" class="nav-link">📅 <span class="nav-text">Availability</span></a>
            <a href="/manager/allocation" class="nav-link">📦 <span class="nav-text">Allocation</span></a>
            <a href="/manager/team" class="nav-link">👥 <span class="nav-text">Team</span></a>
            <a href="/manager/approvals" class="nav-link active">📝 <span class="nav-text">Approvals</span></a>
            <a href="/logout" class="nav-link logout-link">Logout</a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="content">

        <h2>Approval Requests</h2>
        <p class="subtitle">Review and approve pending bookings</p>

        <% if (error) { %>
            <div class="error-box"><%= error %></div>
        <% } %>

        <% if (message) { %>
            <div class="success-box"><%= message %></div>
        <% } %>

        <% if (requests.length === 0) { %>
            <div class="info-text">No pending approval requests.</div>
        <% } else { %>

            <table class="user-table">
                <tr>
                    <th>Team Member</th>
                    <th>Project</th>
                    <th>Date</th>
                    <th>Hours</th>
                    <th>Actions</th>
                </tr>

                <% requests.forEach(r => { %>
                    <tr>
                        <td><%= r.user_name %></td>
                        <td><%= r.project_name %></td>
                        <td><%= r.date %></td>
                        <td><%= r.hours %></td>

                        <td class="actions">

                            <a class="login-btn small-btn" href="/manager/bookings/<%= r.id %>">
                                View
                            </a>

                            <form method="POST" action="/manager/bookings/<%= r.id %>/approve" class="inline-form">
                                <button class="login-btn small-btn" type="submit">Approve</button>
                            </form>

                            <form method="POST" action="/manager/bookings/<%= r.id %>/reject" class="inline-form">
                                <button class="login-btn small-btn warn-btn" type="submit">Reject</button>
                            </form>

                        </td>
                    </tr>
                <% }) %>
            </table>

        <% } %>

        <div class="theme-toggle" onclick="toggleTheme()">🌙 Dark Mode</div>

        <div class="footer-links">
            <a href="/manager/dashboard">Back to Manager Dashboard</a>
        </div>

    </main>

</div>

<script src="/static/logout-modal.js"></script>
<script>
/* Sidebar collapse */
function toggleSidebar() {
    const s = document.getElementById("sidebar");
    s.classList.toggle("collapsed");
    localStorage.setItem("sidebar-collapsed", s.classList.contains("collapsed"));
}

document.addEventListener("DOMContentLoaded", () => {
    if (localStorage.getItem("sidebar-collapsed") === "true") {
        document.getElementById("sidebar").classList.add("collapsed");
    }
});

/* Theme persistence */
const saved = localStorage.getItem("theme");
if (saved) {
    document.documentElement.setAttribute("data-theme", saved);
}
</script>

</body>
</html>
