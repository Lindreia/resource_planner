<% layout('components/layout') %>

<div class="container">
    <h1 class="r8-page-title mb-4">Weekly Dashboard</h1>

    <div class="dashboard-card mb-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="/weekly?week_offset=<%= prev_week %>">Previous Week</a>
            <strong><%= week_label %></strong>
            <a class="btn btn-sm btn-outline-secondary" href="/weekly?week_offset=<%= next_week %>">Next Week</a>
        </div>
    </div>

    <div class="row g-4">
        <% stats_cards.forEach(card => { %>
            <div class="col-md-3">
                <div class="dashboard-card">
                    <div class="dashboard-card-title"><%= card.label %></div>
                    <div class="dashboard-kpi"><%= card.value %></div>
                </div>
            </div>
        <% }) %>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Team Utilisation</div>
                <canvas id="weeklyUtilChart" height="140"></canvas>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Project Hours</div>
                <canvas id="weeklyProjectChart" height="140"></canvas>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Team Detail</div>
                <table class="dashboard-mini-table w-100">
                    <tr><th>Name</th><th>Allocated</th><th>Capacity</th><th>Util %</th></tr>
                    <% team.forEach(t => { %>
                        <tr>
                            <td><%= t.name %></td>
                            <td><%= t.allocated %></td>
                            <td><%= t.capacity %></td>
                            <td><%= t.util %>%</td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-card">
                <div class="dashboard-card-title">Project Detail</div>
                <table class="dashboard-mini-table w-100">
                    <tr><th>Project</th><th>Hours</th><th>Members</th></tr>
                    <% projects.forEach(p => { %>
                        <tr>
                            <td><%= p.code %> - <%= p.name %></td>
                            <td><%= p.hours %></td>
                            <td><%= p.members %></td>
                        </tr>
                    <% }) %>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
    const teamLabels = <%- JSON.stringify(team.map(t => t.name)) %>;
    const teamUtil = <%- JSON.stringify(team.map(t => t.util)) %>;
    const projectLabels = <%- JSON.stringify(projects.map(p => p.code)) %>;
    const projectHours = <%- JSON.stringify(projects.map(p => Number(p.hours) || 0)) %>;

    const utilCtx = document.getElementById("weeklyUtilChart");
    if (utilCtx) {
        new Chart(utilCtx, {
            type: "bar",
            data: { labels: teamLabels, datasets: [{ label: "Util %", data: teamUtil, backgroundColor: "#0b8a4a" }] },
            options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, max: 120 } } }
        });
    }

    const projectCtx = document.getElementById("weeklyProjectChart");
    if (projectCtx) {
        new Chart(projectCtx, {
            type: "doughnut",
            data: { labels: projectLabels, datasets: [{ data: projectHours }] },
            options: { plugins: { legend: { position: "bottom" } } }
        });
    }
})();
</script>
