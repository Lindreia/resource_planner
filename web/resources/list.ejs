<% layout('components/base', { 
    title: "Resource Input", 
    user, 
    active_page: "resources" 
}) %>

<div class="container">

    <h2 class="mb-4">Resource Input</h2>

    <div class="r8-card p-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Team Members</h5>
            <a href="/resources/add" class="btn btn-success btn-sm">
                + Add Resource
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Capacity (hrs)</th>
                        <th>Email</th>
                        <th style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% resources.forEach(r => { %>
                    <tr>
                        <td><%= r.name %></td>
                        <td><%= r.role %></td>
                        <td><%= r.capacity %></td>
                        <td><%= r.email %></td>
                        <td>
                            <a href="/resources/edit/<%= r.id %>" 
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>
                            <a href="/resources/delete/<%= r.id %>" 
                               class="btn btn-sm btn-outline-danger">
                                Del
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </div>

</div>
